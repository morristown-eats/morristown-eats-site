---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <section class="page-section" style="text-align: center; padding: var(--space-24) 0;">
    <div class="container">
      <p class="label" style="display: block; margin-bottom: var(--space-4);">404</p>
      <h1 style="margin-bottom: var(--space-4);">Nothing here.</h1>
      <p style="color: var(--color-ink-muted); font-size: var(--text-lg); margin-bottom: var(--space-8);">
        That page doesn't exist. Maybe the restaurant closed.
      </p>
      <a href="/" class="btn btn-dark">Back to home</a>
    </div>
  </section>
</BaseLayout>
